# Normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.sql  text eol=lf
*.prisma text eol=lf
*.env.example text eol=lf

# Binary files — no EOL conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.svg  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
