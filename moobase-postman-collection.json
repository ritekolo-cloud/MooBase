              "raw": "[\n  {\n    \"id\": \"sync_cattle_101\",\n    \"type\": \"create\",\n    \"entity\": \"cattle\",\n    \"data\": {\n      \"id\": \"C007\",\n      \"tagNumber\": \"TAG-007\",\n      \"name\": \"Chloee\",\n      \"breed\": \"Jersey\",\n      \"age\": 2,\n      \"gender\": \"female\",\n      \"status\": \"healthy\"\n    }\n  },\n  {\n    \"id\": \"sync_record_102\",\n    \"type\": \"create\",\n    \"entity\": \"record\",\n    \"data\": {\n      \"id\": \"sync_R004\",\n      \"cattleId\": \"C007\",\n      \"type\": \"milk\",\n      \"notes\": \"Morning yields\",\n      \"date\": \"2026-06-09T08:00:00.000Z\",\n      \"data\": {\n        \"liters\": 10.5\n      }\n    }\n  }\n]"
